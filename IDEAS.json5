            name: "RC Timer cascading power-on",
            status: "active", // active | paused | abandoned | done
            description: "Cascading RC timer circuit to power on a device after a delay and supply the same power to the next device in the chain. Useful for sequentially powering on multiple devices to avoid inrush current issues.",
            tags: [
                "RC timer",
                "cascading",
                "power-on",
                "sequential",
                "electronics"
